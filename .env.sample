# Bandcamp username to backup
BANDCAMP_USERNAME=your_username

# Path to Node.js binary (default: node)
NODE_BIN=node

# Project directory path
PROJECT_DIR=/path/to/better_bandcamp_wish_list

# Log file path
LOG_FILE=/path/to/better_bandcamp_wish_list/bc_fetch.log

# Bandcamp authentication cookies (REQUIRED)
# Get these from your browser after logging in to Bandcamp
# 1. Open DevTools (F12) > Application > Cookies
# 2. Copy the values for 'identity' and 'js_logged_in'
BANDCAMP_IDENTITY_COOKIE=your_identity_cookie_value
BANDCAMP_JS_LOGGED_IN_COOKIE=1
